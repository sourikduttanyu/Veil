{
  "manifest_version": 3,
  "name": "Veil",
  "version": "0.1.0",
  "description": "Stop ads from stalking you. Veil scrambles your ad data before it ever leaves your device.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "src/background/reporter.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["src/content/detector.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Veil — your data stays yours"
  },
  "homepage_url": "https://github.com/sourikduttanyu/privacap",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
