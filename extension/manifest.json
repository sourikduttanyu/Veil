{
  "manifest_version": 3,
  "name": "privacap",
  "version": "0.1.0",
  "description": "Local differential privacy for ad frequency capping. True counts never leave your browser.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "src/background/reporter.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["src/content/detector.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "privacap — ε-DP frequency capping"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
